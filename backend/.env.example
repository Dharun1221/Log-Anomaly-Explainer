# Copy this file to .env and fill in your values for local development
# On Render, set these as Environment Variables in the dashboard

# Required: Your Google Gemini API key
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Comma-separated list of allowed frontend origins (for CORS)
# Example: https://log-anomaly-explainer-frontend.onrender.com,http://localhost:5173
# If not set, all origins are allowed (current default — restrict in production)
ALLOWED_ORIGINS=https://your-frontend-name.onrender.com
